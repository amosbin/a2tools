#!/bin/sh
set -e

case "$1" in
    remove)
        rm -f /etc/letsencrypt/renewal-hooks/deploy/a2tools
        ;;
    purge)
        rm -f /etc/letsencrypt/renewal-hooks/deploy/a2tools
        rm -rf /var/lib/a2tools /var/cache/a2tools /var/log/a2tools
        rm -rf /etc/a2tools
        ;;
esac

#DEBHELPER#
